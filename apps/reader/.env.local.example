# For develop features related to synchronization,
# you should register an app on Dropbox:
# https://www.dropbox.com/developers/apps/create
NEXT_PUBLIC_DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

NEXT_PUBLIC_WEBSITE_URL=http://localhost:7117

# --- Account system (required for the hosted "R2 / Cloud account" backend) ---

# Managed Postgres connection string. On Vercel, add the Neon/Postgres
# integration and POSTGRES_URL is injected automatically.
# (@vercel/postgres reads POSTGRES_URL; Neon's native integration also works.)
POSTGRES_URL=

# Secret used to sign session JWTs. Generate a long random string, e.g.
# `openssl rand -base64 48`.
JWT_SECRET=

# Bootstrap admin account, created on first request if it doesn't exist.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Cloudflare R2 (hosted storage backend; SERVER-ONLY, never NEXT_PUBLIC) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# WebDAV is configured per-user inside the app (Settings → Synchronization),
# so no env var is needed. The WebDAV server must allow CORS (Authorization
# header + PROPFIND/GET/PUT/DELETE/MKCOL/OPTIONS) for browser-direct access.
